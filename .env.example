# Copy to .env.local for local dev. For GitHub Pages, add these as repository secrets
# (Settings → Secrets → Actions) so the build can embed them.

VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key
# Required if EmailJS Account → Security has "Use Private Key" enabled (strict mode)
VITE_EMAILJS_PRIVATE_KEY=your_private_key

# hCaptcha site key stays in Contact.jsx (public).
